MONGO_DSN="mongodb://localhost/andrey_framework_dev"

# Optional — defaults to redis://localhost. Used for cache and rate limiting.
REDIS_URI="redis://localhost"

HTTP_DOMAIN=""
HTTP_PORT=3300
FRONT_DOMAIN=""

# Required at boot. Generate one with: npm run cli generateRandomBytes
# (the `npm run dev` script auto-fills this via scripts/ensure-env.ts)
AUTH_SALT=""

EMAIL_HOST=""
EMAIL_PORT=2587
EMAIL_USER=""
EMAIL_PASSWORD=""

LOGGER_SENTRY_DSN=""
LOGGER_SENTRY_ENABLE=true
LOGGER_SENTRY_LEVEL="error"
